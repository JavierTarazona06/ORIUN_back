# ORIUN Backend local configuration
# Docker Compose already provides these defaults. Copy this file to .env only
# when you want to override values locally.

# Django
ORIUN_DEBUG=true
DJANGO_SECRET_KEY=django-insecure-local-dev-key-change-in-production
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0,web
CORS_ALLOW_ALL_ORIGINS=true

# PostgreSQL
DATABASE_ENGINE=django.db.backends.postgresql
DATABASE_NAME=oriun
DATABASE_USER=oriun
DATABASE_PASSWORD=oriun
DATABASE_HOST=db
DATABASE_PORT=5432

# Local development integrations
STORAGE_BACKEND=local
LOCAL_STORAGE_ROOT=/app/django_project/data/local_storage
ORIUN_FRONTEND_URL=http://localhost:8080
ORIUN_MAIL_BACKEND=console
ORIUN_BOOTSTRAP_DEMO_DATA=true
ORIUN_CREATE_DEMO_ADMIN=true

# Optional production integrations
# STORAGE_BACKEND=gcs
# GOOGLE_APPLICATION_CREDENTIALS=/app/django_project/credentials.json
# ORIUN_MAIL_BACKEND=smtp
# MAIL_USERNAME=your-service-account@example.com
# MAIL_PASSWORD=your-smtp-password
